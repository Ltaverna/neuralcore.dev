---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import Services from '../../components/Services.astro';
import Process from '../../components/Process.astro';
import Cases from '../../components/Cases.astro';
import Stack from '../../components/Stack.astro';
import Contact from '../../components/Contact.astro';
import Footer from '../../components/Footer.astro';
const lang = 'en' as const;
---
<Base lang={lang} title="NeuralCore — Cloud, Data & AI Engineering" description="Engineering company specialized in cloud platforms, data platforms, platform engineering, AI and MLOps.">
  <Nav lang={lang} />
  <main>
    <Hero lang={lang} />
    <Services lang={lang} />
    <Process lang={lang} />
    <Cases lang={lang} />
    <Stack lang={lang} />
    <Contact lang={lang} />
  </main>
  <Footer lang={lang} />
</Base>
