---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import { caseStudies } from '../content/site';
interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section id="cases" class="border-t border-[var(--color-line)]">
  <div class="mx-auto max-w-5xl px-5 py-20">
    <p class="font-mono text-xs text-accent">{t('cases.kicker')}</p>
    <h2 class="mt-1 text-2xl font-bold tracking-tight text-white md:text-3xl">{t('cases.title')}</h2>

    <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
      {caseStudies.map((c) => (
        <article class="flex flex-col rounded-lg border border-[var(--color-line)] bg-white/[0.02] p-6 transition-colors hover:border-[var(--color-line-accent)]">
          <div class="font-mono text-xs text-accent">[{c.tag}]</div>
          <h3 class="mt-2 text-lg font-bold text-white">{c[lang].title}</h3>

          <div class="mt-4 space-y-3 text-sm">
            <div>
              <span class="font-mono text-[11px] uppercase tracking-wider text-gray-500">{t('cases.challenge')}</span>
              <p class="mt-1 text-gray-400">{c[lang].challenge}</p>
            </div>
            <div>
              <span class="font-mono text-[11px] uppercase tracking-wider text-gray-500">{t('cases.solution')}</span>
              <p class="mt-1 text-gray-400">{c[lang].solution}</p>
            </div>
          </div>

          <div class="mt-5 border-t border-[var(--color-line)] pt-4">
            <span class="font-mono text-[11px] uppercase tracking-wider text-accent">{t('cases.results')}</span>
            <ul class="mt-2 space-y-1 tabular-nums">
              {c[lang].results.map((r) => (
                <li class="flex gap-2 text-sm text-gray-200">
                  <span class="text-accent">▸</span>{r}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
